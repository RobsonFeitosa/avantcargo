# Estágio 1: Build (Compila o TypeScript para JavaScript)
FROM node:20-alpine AS builder

WORKDIR /app

# Copia arquivos de dependências
COPY package*.json ./

# Instala todas as dependências (incluindo as de desenvolvimento para o build)
RUN npm install

# Copia o restante do código da API
COPY . .

# Gera o build (converte TS para a pasta /dist)
RUN npm run build

# Estágio 2: Produção (Execução leve)
FROM node:20-alpine

WORKDIR /app

# Copia apenas o que é essencial do estágio de build
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/dist ./dist

# Instala apenas dependências de produção para economizar espaço
RUN npm install --only=production

# Expõe a porta que sua API usa (ajuste se não for 3000)
EXPOSE 3000

# Comando para rodar a aplicação
CMD ["node", "dist/main.js"]